# Dependencias
node_modules/
backend/node_modules/
frontend/node_modules/

# Variables de entorno
.env
*.env
backend/.env
frontend/.env

# Builds
build/
frontend/build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Sistema
.DS_Store
Thumbs.db

# Backups locales
*.backup.*
BACKUP*/
BackUps/
backups/
backup*/
*.zip
*.sql

# Calendarios descargados / pruebas locales
*.ics

# Temporales
tmp/
temp/
.cache/

cat >> .gitignore <<'EOF'

# Archivos locales sensibles o auxiliares
backend/.env.backup
frontend/.env.backup
.env.backup
*.backup
*.backup.*
*.ics
*.zip
EOF